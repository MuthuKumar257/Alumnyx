{
  "cli": {
    "version": ">= 16.20.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://apialumnyx.development.catalystappsail.in"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://apialumnyx.development.catalystappsail.in"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "apk": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://apialumnyx.development.catalystappsail.in"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://apialumnyx.development.catalystappsail.in"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
