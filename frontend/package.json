{
  "name": "alumnyx-frontend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node ./node_modules/expo/bin/cli start",
    "start:fresh": "node ./scripts/start-fresh.js",
    "start:local": "node ./scripts/start-local.js",
    "android": "node ./node_modules/expo/bin/cli start --android",
    "android:local": "node ./scripts/start-local.js --android",
    "ios": "node ./node_modules/expo/bin/cli start --ios",
    "ios:local": "node ./scripts/start-local.js --ios",
    "web": "node ./node_modules/expo/bin/cli start --web",
    "web:local": "node ./scripts/start-local.js --web",
    "build:apk": "node ./node_modules/eas-cli/bin/run build --platform android --profile apk",
    "build:aab": "node ./node_modules/eas-cli/bin/run build --platform android --profile production"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "axios": "^1.7.2",
    "expo": "^54.0.33",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-image-picker": "~17.0.10",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^0.546.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.1.10",
    "@types/react-native": "^0.72.8",
    "eas-cli": "^18.6.0",
    "expo-module-scripts": "^55.0.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
